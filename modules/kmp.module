# DESC: Kotlin Multiplatform / Gradle (JDK + Gradle)
# HOSTS: services.gradle.org repo.maven.apache.org plugins.gradle.org repo1.maven.org
# The JDK comes from apt. Gradle itself is downloaded per-project by the
# ./gradlew wrapper, and KMP builds pull dependencies from Maven Central and the
# Gradle plugin portal — hence the firewall hosts. Builds the JVM/desktop
# targets; Android builds need the SDK, which isn't installed here.
install_module() {
    apt-get install -y --no-install-recommends openjdk-21-jdk-headless ca-certificates curl unzip
}
